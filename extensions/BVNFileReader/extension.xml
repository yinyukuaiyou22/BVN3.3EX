<?xml version="1.0" encoding="UTF-8"?>
<extension xmlns="http://ns.adobe.com/air/extension/32.0">
    <id>com.bvn.filereader</id>
    <versionNumber>1.0</versionNumber>
    <platforms>
        <platform name="Android-ARM64">
            <applicationDeployment>
                <nativeLibrary>BVNFileReader.jar</nativeLibrary>
                <initializer>com.bvn.filereader.BVNFileReaderExtension</initializer>
            </applicationDeployment>
            <manifestAdditions>
<![CDATA[
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <provider
            android:name="com.bvn.filereader.BVNDataFilesProvider"
            android:authorities="air.com.bvn.yinyu.BVNDataFilesProvider"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER"/>
            </intent-filter>
        </provider>
        <activity
            android:name="com.bvn.filereader.BVNDataFilesWakeUpActivity"
            android:taskAffinity="air.com.bvn.yinyu.BVNDataFilesWakeUp"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"/>
    </application>
</manifest>
]]>
            </manifestAdditions>
        </platform>
    </platforms>
</extension>
