# Headroom / Claude Code — 排除文件列表
# 语法同 .gitignore

# 编译产物
*.swf
*.swc
*.apk
*.ipa

# 嵌入资源（二进制大文件）
*.png
*.jpg
*.jpeg
*.mp3
*.wav
*.bin
*.gif
_assets/

# 外部加载资源
assets/swf/
assets/*.swf

# SDK / 工具链（无需分析）
AIRSDK/
tools/Test/

# 参考/基线代码（只读）
last/
OLD/
reference/BVN3.9/
reference/MTDataFilesProvider/

# 导出目录
Outscripts/

# 常规忽略
node_modules/
dist/
.git/
__pycache__/
*.pyc
.venv/
venv/
